[Unit]
Description=Orion-Sentinel-DataAICore Docker Compose Stack
Documentation=https://github.com/orionsentinel/Orion-Sentinel-DataAICore
After=docker.service
Requires=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes

# ============================================================================
# IMPORTANT: Replace __USERNAME__ with your actual username before installing
# Example: if your username is 'admin', change __USERNAME__ to admin
# ============================================================================

WorkingDirectory=/home/__USERNAME__/Orion-Sentinel-DataAICore
User=__USERNAME__
Group=__USERNAME__

# Environment file
EnvironmentFile=/home/__USERNAME__/Orion-Sentinel-DataAICore/.env

# Start all core services
ExecStart=/usr/bin/docker compose --profile nextcloud --profile websearch --profile llm up -d

# Stop all services
ExecStop=/usr/bin/docker compose --profile nextcloud --profile websearch --profile llm down

# Restart policy
Restart=on-failure
RestartSec=10

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=dataaicore

[Install]
WantedBy=multi-user.target

# ============================================================================
# Installation Instructions:
#
# 1. Copy this file to systemd:
#    sudo cp systemd/dataaicore.service /etc/systemd/system/
#
# 2. Edit the file and replace __USERNAME__ with your username:
#    sudo nano /etc/systemd/system/dataaicore.service
#    # Use Ctrl+\ in nano to find/replace __USERNAME__
#    # Or use: sudo sed -i "s/__USERNAME__/$USER/g" /etc/systemd/system/dataaicore.service
#
# 3. Reload systemd:
#    sudo systemctl daemon-reload
#
# 4. Enable to start on boot:
#    sudo systemctl enable dataaicore
#
# 5. Start the service:
#    sudo systemctl start dataaicore
#
# 6. Check status:
#    sudo systemctl status dataaicore
#
# 7. View logs:
#    sudo journalctl -u dataaicore -f
#
# ============================================================================
