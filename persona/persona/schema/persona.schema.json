{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://persona.local/schema/persona.schema.json",
  "title": "Persona Profile File Frontmatter",
  "description": "JSON Schema for YAML frontmatter blocks in Persona USER/ profile files",
  "type": "object",
  "required": ["ring", "last_updated", "version"],
  "properties": {
    "ring": {
      "type": "integer",
      "minimum": 1,
      "maximum": 3,
      "description": "Access ring: 1=public, 2=contextual, 3=sensitive"
    },
    "last_updated": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "ISO 8601 date of last update (YYYY-MM-DD)"
    },
    "version": {
      "type": "integer",
      "minimum": 1,
      "description": "Monotonically increasing version number"
    }
  },
  "additionalProperties": true
}
