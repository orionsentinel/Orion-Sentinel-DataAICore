# ============================================================================
# Orion-Sentinel-DataAICore - Environment Configuration
# ============================================================================
#
# Copy this file to .env in the repository root:
#   cp env/.env.example .env
#
# The bootstrap script (scripts/bootstrap-dataaicore.sh) will copy this file
# and generate secure secrets automatically.
#
# To edit after installation:
#   sudo nano .env
#
# ============================================================================

# ============================================================================
# SYSTEM SETTINGS
# ============================================================================

# Timezone
# List: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Europe/Amsterdam

# Host IP address for port binding
# Use your LAN IP (e.g., 192.168.1.100) for LAN-only access
# Or use 127.0.0.1 for localhost-only (most secure)
# Default 127.0.0.1 means services only accessible from the host itself
HOST_IP=127.0.0.1

# Data root directory
# All application data is stored under this directory
DATA_ROOT=/srv/orion/dataaicore

# User and Group IDs (optional - find with: id)
PUID=1000
PGID=1000

# ============================================================================
# NEXTCLOUD (Profile: nextcloud)
# ============================================================================

# Admin credentials (only used on first container start)
# IMPORTANT: Change password in Nextcloud UI after first login
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=CHANGE_ME_GENERATED_BY_BOOTSTRAP

# Trusted domains (space-separated)
# Add your server's IP and any domain names
NEXTCLOUD_TRUSTED_DOMAINS=localhost

# PostgreSQL database settings
POSTGRES_DB=nextcloud
POSTGRES_USER=nextcloud
POSTGRES_PASSWORD=CHANGE_ME_GENERATED_BY_BOOTSTRAP

# Redis settings
REDIS_PASSWORD=CHANGE_ME_GENERATED_BY_BOOTSTRAP

# PHP settings
PHP_MEMORY_LIMIT=512M
PHP_UPLOAD_MAX_SIZE=16G
PHP_MAX_EXECUTION_TIME=3600

# ============================================================================
# SEARXNG (Profile: websearch)
# ============================================================================

# SearXNG port (default: 8888)
SEARXNG_PORT=8888

# Secret key for secure cookies
SEARXNG_SECRET_KEY=CHANGE_ME_GENERATED_BY_BOOTSTRAP

# ============================================================================
# LLM STACK (Profile: llm)
# ============================================================================

# Open WebUI secret key (session encryption)
WEBUI_SECRET_KEY=CHANGE_ME_GENERATED_BY_BOOTSTRAP

# Allow new user signups (set to false after creating your account)
ENABLE_SIGNUP=true

# ============================================================================
# PUBLIC NEXTCLOUD (Profile: public-nextcloud) - OPTIONAL
# ============================================================================

# Your domain name for public Nextcloud access
# Only set this if you plan to expose Nextcloud to the internet
# Nextcloud will be accessible at: cloud.${ORION_DOMAIN}
ORION_DOMAIN=yourdomain.com

# ============================================================================
# NOTES
# ============================================================================
#
# Profile Usage:
#   ./scripts/orionctl up nextcloud      # Nextcloud + Postgres + Redis
#   ./scripts/orionctl up websearch      # SearXNG
#   ./scripts/orionctl up llm            # Ollama + Open WebUI
#   ./scripts/orionctl up core           # All of the above
#
# Security:
#   - All services are LOCAL ONLY by default
#   - Published to LAN on ${HOST_IP}:<port>
#   - NOT exposed to the internet
#   - For remote access without public exposure, use VPN
#
# Public Nextcloud (Phase 2):
#   - Requires: domain name, DNS A record, router port forwarding (443)
#   - Enable with: ./scripts/orionctl up nextcloud public-nextcloud
#   - Only Nextcloud is exposed; other services remain LAN-only
#   - See SECURITY.md for requirements
#
# LLM Models:
#   Small (CPU-friendly):
#     ./scripts/pull-model.sh llama3.2:3b
#     ./scripts/pull-model.sh qwen2.5:3b
#
#   Medium (requires more RAM):
#     ./scripts/pull-model.sh llama3.2:7b
#
# Backups:
#   Critical data to backup:
#     - ${DATA_ROOT}/nextcloud/postgres (database)
#     - ${DATA_ROOT}/nextcloud/app (application data)
#     - .env file (configuration + secrets)
#
# ============================================================================
